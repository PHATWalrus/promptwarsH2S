{
  "name": "lexguard",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/worker",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "bun test",
    "db:migrate": "turbo run db:migrate --filter=@lexguard/db",
    "db:generate": "turbo run db:generate --filter=@lexguard/db",
    "db:studio": "cd packages/db && bunx drizzle-kit studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  }
}
