# App
NODE_ENV=development
PORT=3001
API_VERSION=v1
API_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,https://lexguard.app
# Production requires HTTPS API_BASE_URL and exact ALLOWED_ORIGINS values, never "*".

# Database
DATABASE_URL=postgresql://lexguard:password@localhost:5432/lexguard
DATABASE_MAX_CONNECTIONS=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lexguard:

# Storage (S3-compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lexguard-contracts
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true
# Production storage endpoints must use HTTPS, for example Cloudflare R2.

# Auth
BETTER_AUTH_SECRET=change-this-better-auth-secret-min-32-chars
JWT_ACCESS_SECRET=change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-too-different-from-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AI
GEMINI_API_KEY=AIza...
GEMINI_SEARCH_GROUNDING=true
DEFAULT_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Crawling
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
FIRECRAWL_API_KEY=
CRAWL_PROVIDER=cloudflare

# Rate Limiting
RATE_LIMIT_UPLOAD_PER_HOUR=10
RATE_LIMIT_CHAT_PER_HOUR=30

# Upload scanning
# Use disabled only for local development and tests. Production requires http plus UPLOAD_SCANNER_URL.
UPLOAD_SCANNER_MODE=disabled
UPLOAD_SCANNER_URL=

# Worker
WORKER_CONCURRENCY=5
ANALYSIS_TIMEOUT_MS=120000
OCR_SERVICE_URL=
